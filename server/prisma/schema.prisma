generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  admin
  agent
}

enum TicketStatus {
  open
  resolved
  closed
}

enum TicketCategory {
  general_question
  technical_question
  refund_request
}

enum MessageSender {
  customer
  agent
  ai
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(agent)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]
}

model Ticket {
  id              String         @id @default(cuid())
  subject         String
  body            String
  sourceEmail     String
  status          TicketStatus   @default(open)
  category        TicketCategory?
  aiSummary       String?
  aiSuggestedReply String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  messages        Message[]
}

model Message {
  id        String        @id @default(cuid())
  body      String
  sender    MessageSender
  ticketId  String
  ticket    Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?         @relation(fields: [userId], references: [id])
  sentAt    DateTime      @default(now())
}
