# Server
PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/helpdesk
CLIENT_URL=http://localhost:5173
BETTER_AUTH_SECRET=change-this-to-a-long-random-secret-32chars
BETTER_AUTH_URL=http://localhost:5000
SEED_EMAIL=admin@example.com
SEED_PASSWORD=REPLACE_ME_MIN_16_CHARS
SEED_NAME=Admin

WEBHOOK_SECRET=your-webhook-secret-here
OPENAI_API_KEY=your-openai-api-key

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=support@yourdomain.com

# Sentry (server) — leave blank to disable locally
SENTRY_DSN=
# Sentry build-time vars — only needed in CI for source map uploads
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Client (Vite env vars must be prefixed with VITE_) — set in client/.env
VITE_API_URL=http://localhost:5000
# Sentry (client) — leave blank to disable locally
VITE_SENTRY_DSN=
